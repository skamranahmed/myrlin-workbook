# Dependencies
node_modules/

# Runtime state & credentials (contains passwords, session data, PIDs)
/state/

# Claude account snapshots (plaintext OAuth tokens; never commit)
state/claude-accounts/
**/claude-accounts/

# Uploaded images (per-session image attachments)
/uploads/

# Claude Code local settings (permissions, project-specific config)
.claude/

# Environment and secrets
.env
.env.*
*.pem
*.key

# Logs
*.log
/logs/

# OS files
.DS_Store
Thumbs.db
nul

