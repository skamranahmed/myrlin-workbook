# Generated output
screenshots/
dist/

# Marketing pipeline (scripts + generated output)
scripts/marketing/
marketing/

# Autostart helper script (generated by setup-autostart.ps1; user-specific paths)
scripts/autostart-wrapper.cmd

# Frontend backup snapshots
src/web/public/.backup/
.todos/

# GSD planning artifacts (ephemeral, not for public repo)
.planning/

# Cron run state (per-machine)
cron-full.json
cron-runs.json
